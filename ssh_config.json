{
  "host": "putin2",
  "port": 44122,
  "user": "tino",
  "timeout": 30000,
  "maxChars": "none",
  "security": {
    "commandWhitelist": [
      "ls",
      "cat", 
      "echo",
      "ps",
      "whoami",
      "grep",
      "tail",
      "head",
      "wc",
      "find",
      "df",
      "du",
      "free",
      "uname",
      "date",
      "uptime",
      "^ps.*",
      "^ls.*",
      "^cat.*"
    ],
    "commandBlacklist": [
      "rm",
      "dd",
      "format",
      "fdisk",
      "shutdown",
      "reboot",
      "halt",
      "poweroff",
      "sudo",
      "su",
      "passwd",
      "chmod",
      "chown",
      "mkfs",
      "fsck",
      "mount",
      "umount",
      "kill",
      "killall",
      "pkill",
      "init",
      "systemctl",
      "service",
      "iptables",
      "ufw",
      "crontab",
      "at",
      "batch"
    ],
    "auditLogging": true,
    "sanitizeErrors": true,
    "encodePasswords": true
  },
  "logging": {
    "level": "INFO",
    "includeTimestamp": true,
    "includeUserInfo": true
  }
}
